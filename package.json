{
  "name": "fcp-mpdp-frontend",
  "version": "0.0.0",
  "description": "CDP Frontend Template",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build:frontend": "vite build",
    "dev": "npm-run-all2 --parallel frontend:watch server:watch",
    "dev:debug": "npm-run-all2 --parallel frontend:watch server:debug",
    "docker:build": "docker compose --profile app build",
    "docker:dev": "docker compose --profile app up",
    "frontend:watch": "vite build --mode development --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "postversion": "git add package.json package-lock.json && git commit -m $npm_package_version",
    "server:debug": "node --env-file-if-exists=.env --watch --watch-path=./src --watch-path=./.public/assets-manifest.json --inspect src/index.js",
    "server:watch": "node --env-file-if-exists=.env --watch --watch-path=./src --watch-path=./.public/assets-manifest.json src/index.js",
    "start": "NODE_ENV=production node .",
    "test": "cross-env TZ=UTC vitest run --coverage",
    "test:unit": "cross-env TZ=UTC vitest run --coverage --project unit",
    "test:integration": "cross-env TZ=UTC vitest run --coverage --project integration",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:debug": "cross-env TZ=UTC vitest --inspect --no-file-parallelism"
  },
  "author": "Defra DDTS",
  "contributors": [
    "Rana Salem <rana.salem@defra.gov.uk>",
    "John Watson <john.watson1@defra.gov.uk>",
    "Jayne Elliott <jayne.elliott@defra.gov.uk>",
    "Lawrence Sithole <Lawrence.Sithole@defra.gov.uk>"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-sts": "3.1055.0",
    "@defra/hapi-tracing": "1.22.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/crumb": "9.0.1",
    "@hapi/hapi": "21.4.0",
    "@hapi/inert": "7.1.1",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/wreck": "18.1.2",
    "@hapi/yar": "11.0.3",
    "aws-embedded-metrics": "4.2.0",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "date-fns": "4.1.0",
    "global-agent": "3.0.0",
    "govuk-frontend": "6.1.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "4.0.0",
    "joi": "18.2.1",
    "node-fetch": "3.3.2",
    "nunjucks": "3.2.4",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "semver": "7.7.2",
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.4",
    "cheerio": "1.1.0",
    "cross-env": "7.0.3",
    "eslint": "9.29.0",
    "jsdom": "26.1.0",
    "neostandard": "0.12.1",
    "npm-run-all2": "7.0.2",
    "sass": "1.89.2",
    "stylelint": "16.21.0",
    "stylelint-config-gds": "2.0.0",
    "vite": "8.1.0",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5"
  }
}
